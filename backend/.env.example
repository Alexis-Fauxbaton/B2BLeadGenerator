# Laisser vide pour utiliser le fallback local (templates).
# Renseigner une clé pour générer les messages via OpenAI.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

DATABASE_URL=sqlite:///./chr_signal_radar.db

# Clé Google Places (New) — optionnelle. Vide = enrichissement contact gratuit (OSM + scrape).
GOOGLE_PLACES_API_KEY=

# Auth légère (comptes closers). Secret de signature des cookies de session.
# Vide = secret ÉPHÉMÈRE généré au démarrage (le login marche, mais les sessions
# ne survivent PAS à un redémarrage du serveur). En prod, poser une valeur stable :
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# Origine(s) autorisée(s) pour les cookies cross-origin (CORS). Liste séparée par
# des virgules. Défaut : le frontend Next.js en dev. OBLIGATOIRE d'être explicite
# (pas de "*") dès que les cookies de session sont utilisés.
CORS_ORIGINS=http://localhost:3000

# NOTE cookie cross-origin (SameSite/Secure) : le cookie de session est posé en
# SameSite=Lax aujourd'hui, ce qui marche tant que front (Next.js) et back
# (FastAPI) sont vus comme la MÊME origine par le navigateur (dev localhost, ou
# prod derrière un seul domaine/reverse-proxy). Le jour où front et back sont
# servis depuis des domaines DIFFÉRENTS en HTTPS (ex. app.example.com qui
# appelle api.example.com), il faudra passer le cookie en Secure=True +
# SameSite=None (voir set_cookie dans app/routes/auth.py) — sinon le navigateur
# rejette silencieusement le cookie et le login semblera cassé (login 200 mais
# /me reste null juste après).
